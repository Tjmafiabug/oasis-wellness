---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';

const locations = site.locations;
const services = site.bookServices;
---

<Layout
  title="Book an Appointment — OASIS Wave of Wellness"
  description="Reserve your wellness session at OASIS Wave of Wellness. Three locations across Delhi NCR — Noida Sector 18, Gurgaon DLF Phase 1, Ghaziabad Indirapuram."
>
  <Nav />
  <main>

    <!-- Page Hero -->
    <section class="page-hero section--dark">
      <div class="container page-hero__inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">→</span>
          <span>Book</span>
        </nav>
        <span class="label label--gold">Reservations</span>
        <h1 class="heading-display">Begin Your<br /><em>Journey</em></h1>
        <p class="page-hero__sub">Choose your location. We'll take care of everything else.</p>
      </div>
    </section>

    <!-- Booking Layout -->
    <section class="section booking-section" id="book">
      <div class="container booking-section__inner">

        <!-- ── Booking Form ── -->
        <div class="booking-form-wrap">
          <div class="form-header">
            <span class="label">Request an Appointment</span>
            <h2 class="heading-lg form-header__title">Book Your Session</h2>
            <div class="divider divider--left"></div>
            <p class="body-sm form-header__sub">
              Fill in your details and we'll confirm within 2 hours via WhatsApp or call.
            </p>
          </div>

          <form class="booking-form" id="booking-form" novalidate>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label class="form-label" for="fname">First Name *</label>
                <input class="form-input" type="text" id="fname" name="fname" placeholder="Priya" required />
              </div>
              <div class="form-field">
                <label class="form-label" for="lname">Last Name</label>
                <input class="form-input" type="text" id="lname" name="lname" placeholder="Sharma" />
              </div>
            </div>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label class="form-label" for="phone">Mobile Number *</label>
                <input class="form-input" type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
              </div>
              <div class="form-field">
                <label class="form-label" for="email">Email Address</label>
                <input class="form-input" type="email" id="email" name="email" placeholder="priya@example.com" />
              </div>
            </div>

            <div class="form-field">
              <label class="form-label" for="service">Service of Interest *</label>
              <div class="select-wrap">
                <select class="form-input form-select" id="service" name="service" required>
                  <option value="" disabled selected>Select a service…</option>
                  {services.map(s => <option value={s}>{s}</option>)}
                </select>
                <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            </div>

            <fieldset class="form-field form-fieldset">
              <legend class="form-label">Preferred Location *</legend>
              <div class="location-pills">
                {locations.map(l => (
                  <label class="location-pill">
                    <input type="radio" name="location" value={l.id} required />
                    <span class="location-pill__label">
                      <strong>{l.city}</strong>
                      <small>{l.area}</small>
                    </span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="form-row form-row--2">
              <div class="form-field">
                <label class="form-label" for="date">Preferred Date</label>
                <input class="form-input" type="date" id="date" name="date" />
              </div>
              <div class="form-field">
                <label class="form-label" for="time">Preferred Time</label>
                <div class="select-wrap">
                  <select class="form-input form-select" id="time" name="time">
                    <option value="" disabled selected>Select time…</option>
                    <option>Morning (10 AM – 1 PM)</option>
                    <option>Afternoon (1 PM – 4 PM)</option>
                    <option>Evening (4 PM – 8 PM)</option>
                  </select>
                  <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-field">
              <label class="form-label" for="notes">Anything We Should Know?</label>
              <textarea
                class="form-input form-textarea"
                id="notes"
                name="notes"
                placeholder="Skin concerns, allergies, previous treatments…"
                rows="4"
              ></textarea>
            </div>

            <button type="submit" class="btn btn--solid btn--submit" id="submit-btn">
              Request Appointment →
            </button>
            <p class="form-note">No payment required. We confirm within 2 hours via WhatsApp or call.</p>

          </form>
        </div>

        <!-- ── Sidebar ── -->
        <aside class="booking-sidebar">
          <div class="sidebar-section">
            <h3 class="sidebar-section__head">Our Locations</h3>
            <div class="location-cards">
              {locations.map(l => (
                <div class="location-card">
                  <div class="location-card__head">
                    <div>
                      <span class="location-card__city">{l.city}</span>
                      <span class="location-card__area">{l.area}</span>
                    </div>
                    <div class="location-card__rating-wrap">
                      <span class="location-card__rating">{l.rating}</span>
                      <span class="location-card__reviews">{l.reviews}</span>
                    </div>
                  </div>
                  <p class="location-card__address">{l.address}</p>
                  <p class="location-card__hours">{l.hours}</p>
                  <div class="location-card__actions">
                    <a href={`tel:${l.phone.replace(/\s/g, '')}`} class="location-card__action">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.27a16 16 0 006.29 6.29l1.8-1.8a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/>
                      </svg>
                      Call
                    </a>
                    <a
                      href={`https://wa.me/${l.whatsapp}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="location-card__action location-card__action--wa"
                    >
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                      </svg>
                      WhatsApp
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="walkin-note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <p><strong>Walk-ins welcome</strong> — subject to availability. Booking ahead guarantees your preferred time slot.</p>
          </div>

          <div class="response-guarantee">
            <span class="label">Our Promise</span>
            <p class="response-guarantee__text">We respond to every booking request within 2 hours during operating hours. After hours, we'll reach out first thing in the morning.</p>
          </div>
        </aside>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Page Hero ── */
  .page-hero {
    min-height: 320px;
    display: flex;
    align-items: center;
    padding: var(--2xl) 0;
  }

  .page-hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--md);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--xs);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
    margin-bottom: var(--xs);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color var(--duration-sm);
  }

  .breadcrumb a:hover { color: rgba(255,255,255,0.9); }

  .page-hero .heading-display { color: #fff; }

  .page-hero .heading-display em {
    font-style: italic;
    color: var(--gold-light);
  }

  .page-hero__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    max-width: 44ch;
    margin-top: var(--xs);
  }

  /* ── Booking Layout ── */
  .booking-section__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--2xl);
    align-items: start;
  }

  /* ── Form ── */
  .form-header { margin-bottom: var(--xl); }

  .form-header__title {
    margin-top: var(--sm);
    margin-bottom: var(--md);
  }

  .form-header__sub {
    margin-top: var(--md);
    color: var(--text-muted);
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: var(--lg);
  }

  .form-row { display: grid; gap: var(--md); }
  .form-row--2 { grid-template-columns: 1fr 1fr; }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }

  .form-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
  }

  .form-input {
    width: 100%;
    background: #fff;
    border: 1px solid var(--border-dark);
    padding: 12px var(--md);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text);
    outline: none;
    transition: border-color var(--duration-sm), box-shadow var(--duration-sm);
    appearance: none;
    -webkit-appearance: none;
  }

  .form-input::placeholder { color: var(--text-faint); }

  .form-input:focus {
    border-color: var(--green-default);
    box-shadow: 0 0 0 3px rgba(79,107,56,0.08);
  }

  .select-wrap { position: relative; }

  .select-wrap .form-input {
    padding-right: 36px;
    cursor: pointer;
  }

  .select-arrow {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--text-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  /* Location pills (in form) */
  .location-pills {
    display: flex;
    gap: var(--sm);
    flex-wrap: wrap;
    margin-top: 6px;
  }

  .location-pill { cursor: pointer; }

  .location-pill input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .location-pill__label {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--sm) var(--md);
    border: 1px solid var(--border-dark);
    background: #fff;
    cursor: pointer;
    transition: border-color var(--duration-sm), background var(--duration-sm);
  }

  .location-pill__label strong {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  .location-pill__label small {
    font-size: 0.68rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .location-pill input:checked + .location-pill__label {
    border-color: var(--green-default);
    background: var(--green-lightest);
  }

  .location-pill input:checked + .location-pill__label strong {
    color: var(--green-dark);
  }

  /* Submit */
  .btn--submit {
    width: 100%;
    justify-content: center;
    padding: 16px 32px;
    font-size: 0.75rem;
  }

  .form-note {
    font-size: 0.75rem;
    color: var(--text-faint);
    text-align: center;
    margin-top: calc(-1 * var(--xs));
  }

  /* ── Sidebar ── */
  .booking-sidebar {
    position: sticky;
    top: 140px;
    display: flex;
    flex-direction: column;
    gap: var(--xl);
  }

  .sidebar-section__head {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--md);
  }

  /* Location cards (sidebar) */
  .location-cards {
    display: flex;
    flex-direction: column;
    gap: var(--sm);
  }

  .location-card {
    background: #fff;
    border: 1px solid var(--border);
    padding: var(--md);
    transition: border-color var(--duration-sm);
  }

  .location-card:hover { border-color: var(--green-default); }

  .location-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--md);
    margin-bottom: var(--xs);
  }

  .location-card__city {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .location-card__area {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .location-card__rating-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .location-card__rating {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--gold-default);
    font-weight: 500;
    line-height: 1;
  }

  .location-card__reviews {
    font-size: 0.65rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  .location-card__address {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .location-card__hours {
    font-size: 0.72rem;
    color: var(--text-faint);
    margin-bottom: var(--sm);
  }

  .location-card__actions {
    display: flex;
    gap: var(--xs);
  }

  .location-card__action {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-default);
    border: 1px solid var(--green-default);
    padding: 6px 12px;
    transition: background var(--duration-sm), color var(--duration-sm);
  }

  .location-card__action:hover {
    background: var(--green-default);
    color: #fff;
  }

  .location-card__action--wa {
    color: #25D366;
    border-color: #25D366;
  }

  .location-card__action--wa:hover {
    background: #25D366;
    color: #fff;
  }

  /* Walk-in note */
  .walkin-note {
    display: flex;
    gap: var(--sm);
    align-items: flex-start;
    background: var(--gold-tint);
    border: 1px solid var(--gold-light);
    padding: var(--md);
  }

  .walkin-note svg {
    color: var(--gold-dark);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .walkin-note p {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.55;
  }

  .walkin-note strong { color: var(--gold-dark); }

  /* Response guarantee */
  .response-guarantee {
    padding: var(--md);
    border: 1px solid var(--border);
    background: var(--green-lightest);
  }

  .response-guarantee .label {
    display: block;
    margin-bottom: var(--xs);
  }

  .response-guarantee__text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .booking-section__inner { grid-template-columns: 1fr; }

    .booking-sidebar {
      position: static;
      order: -1;
    }

    .location-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .form-row--2 { grid-template-columns: 1fr; }
    .location-cards { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .location-pills { flex-direction: column; }
  }
</style>

<script define:vars={{ waNumbers: Object.fromEntries(site.locations.map(l => [l.id, l.whatsapp])) }}>
  const form = document.getElementById('booking-form');
  const btn  = document.getElementById('submit-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data     = new FormData(form);
    const fname    = (data.get('fname') || '').toString().trim();
    const lname    = (data.get('lname') || '').toString().trim();
    const phone    = (data.get('phone') || '').toString();
    const service  = (data.get('service') || '').toString();
    const location = (data.get('location') || '').toString();
    const date     = (data.get('date') || '').toString();
    const time     = (data.get('time') || '').toString();
    const notes    = (data.get('notes') || '').toString().trim();

    const waNum = waNumbers[location] ?? waNumbers.noida;

    const lines = [
      `Hi OASIS! I'd like to book an appointment. 🌿`,
      ``,
      `*Name:* ${[fname, lname].filter(Boolean).join(' ')}`,
      `*Phone:* ${phone}`,
      `*Service:* ${service}`,
      `*Location:* ${location.charAt(0).toUpperCase() + location.slice(1)}`,
      date  ? `*Date:* ${date}`  : '',
      time  ? `*Time:* ${time}`  : '',
      notes ? `*Notes:* ${notes}` : '',
    ].filter(l => l !== null);

    const msg = lines.join('\n').trim();

    window.open(`https://wa.me/${waNum}?text=${encodeURIComponent(msg)}`, '_blank');

    if (btn) {
      btn.textContent = '✓ Opening WhatsApp…';
      btn.disabled = true;
      btn.style.background = 'var(--green-darkest)';
      btn.style.cursor = 'default';
    }
  });
</script>
