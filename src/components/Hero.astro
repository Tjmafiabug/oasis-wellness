---
import { site } from '../config/site';
const slides = site.heroSlides;
---

<section class="hero" id="hero">
  <!-- Slides -->
  {slides.map((s, i) => (
    <div class={`hero__slide${i === 0 ? ' hero__slide--active' : ''}`} data-index={i}>
      <img
        src={s.img}
        alt={s.label}
        class="hero__slide-img"
        loading={i === 0 ? 'eager' : 'lazy'}
      />
      <div class="hero__overlay"></div>
      <div class="hero__slide-content container">
        <span class="label label--white">{s.label}</span>
        <h1 class="heading-display hero__heading">{s.line1}<br />{s.line2}</h1>
        <p class="hero__sub">{s.sub}</p>
        <div class="hero__actions">
          <a href="/book" class="btn btn--gold">Book A Session</a>
          <a href="/services" class="btn btn--outline-white">Explore Services</a>
        </div>
      </div>
    </div>
  ))}

  <!-- Dots -->
  <div class="hero__dots" role="tablist" aria-label="Slides">
    {slides.map((s, i) => (
      <button
        class={`hero__dot${i === 0 ? ' hero__dot--active' : ''}`}
        data-slide={i}
        role="tab"
        aria-label={`Slide ${i + 1}: ${s.label}`}
        aria-selected={i === 0 ? 'true' : 'false'}
      ></button>
    ))}
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style is:global>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
  }

  /* ── Slides ── */
  .hero__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hero__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero__slide-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      0deg,
      rgba(0,0,0,0.78) 0%,
      rgba(0,0,0,0.5) 30%,
      rgba(0,0,0,0.2) 60%,
      rgba(0,0,0,0.35) 100%
    );
  }

  /* ── Slide Content ── */
  .hero__slide-content {
    position: relative;
    z-index: 2;
    color: #fff;
    padding-top: var(--2xl);
    width: 100%;
  }

  .hero__heading {
    color: #fff;
    margin-top: var(--md);
    max-width: 14ch;
  }

  .hero__sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    margin-top: var(--lg);
    max-width: 44ch;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--md);
    margin-top: var(--xl);
    flex-wrap: wrap;
  }

  /* ── Dots ── */
  .hero__dots {
    position: absolute;
    bottom: var(--xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: var(--xs);
    z-index: 10;
  }

  .hero__dot {
    position: relative;
    width: 32px;
    height: 2px;
    background: rgba(255,255,255,0.3);
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: background var(--duration-md);
  }

  .hero__dot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold-default);
    transform: scaleX(0);
    transform-origin: left;
  }

  .hero__dot--active::after {
    animation: dotFill 5s linear forwards;
  }

  @keyframes dotFill {
    to { transform: scaleX(1); }
  }

  /* ── Scroll indicator ── */
  .hero__scroll {
    position: absolute;
    bottom: var(--xl);
    right: var(--2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--xs);
    z-index: 10;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.2);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: -40px;
    left: 0;
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.7);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%   { top: -40px; }
    100% { top: 40px; }
  }

  @media (max-width: 768px) {
    .hero__scroll { display: none; }
    .hero__sub br { display: none; }
    .hero__slide-content { padding-top: var(--xl); }
    .hero { min-height: 520px; }
  }

  @media (max-width: 480px) {
    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }
    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const DELAY = 5000;
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const dots   = document.querySelectorAll<HTMLButtonElement>('.hero__dot');
  const hero   = document.getElementById('hero')!;
  let current  = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(n: number) {
    slides[current].classList.remove('hero__slide--active');
    dots[current].classList.remove('hero__dot--active');
    dots[current].setAttribute('aria-selected', 'false');

    current = (n + slides.length) % slides.length;

    slides[current].classList.add('hero__slide--active');

    // Force animation restart on dot
    const dot = dots[current];
    dot.classList.remove('hero__dot--active');
    void dot.offsetWidth; // reflow
    dot.classList.add('hero__dot--active');
    dot.setAttribute('aria-selected', 'true');
  }

  function start() {
    timer = setInterval(() => goTo(current + 1), DELAY);
  }

  function stop() {
    clearInterval(timer);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      stop();
      goTo(i);
      start();
    });
  });

  hero.addEventListener('mouseenter', stop);
  hero.addEventListener('mouseleave', start);

  start();
</script>
