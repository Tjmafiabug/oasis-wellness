---
import { site } from '../config/site';
const pillars = site.whyUsPillars;
---

<section class="section section--tinted" id="about">
  <div class="container">
    <div class="whyus">
      <!-- Image side -->
      <div class="whyus__image">
        <img
          src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=900&q=80&auto=format&fit=crop&crop=faces"
          alt="Wellness practitioner"
          loading="lazy"
        />
        <div class="whyus__badge">
          <span class="whyus__badge-num">10+</span>
          <span class="whyus__badge-text">Years of<br/>Expertise</span>
        </div>
      </div>

      <!-- Content side -->
      <div class="whyus__content">
        <span class="label">A Trailblazer In Wellness</span>
        <h2 class="heading-lg" style="margin-top: 0.75rem;">
          Where Science<br />Meets Self-Care
        </h2>
        <div class="divider divider--left" style="margin-top: 1rem;"></div>
        <p class="body-lg" style="margin-top: 1.25rem; margin-bottom: 2rem;">
          Wellness is personal. At OASIS, we celebrate that no two paths are the same
          by offering a breadth of experiences for every kind of journey — inspired by five pillars.
        </p>

        <ul class="pillars">
          {pillars.map(p => (
            <li class="pillar">
              <div class="pillar__icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--green-default)" xmlns="http://www.w3.org/2000/svg">
                  <Fragment set:html={p.icon} />
                </svg>
              </div>
              <div class="pillar__text">
                <h4 class="pillar__title">{p.title}</h4>
                <p class="body-sm">{p.desc}</p>
              </div>
            </li>
          ))}
        </ul>

        <a href="#book" class="btn btn--solid" style="margin-top: 2rem;">Start Your Journey</a>
      </div>
    </div>
  </div>
</section>

<style>
  .whyus {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--2xl);
    align-items: center;
  }

  .whyus__image {
    position: relative;
  }

  .whyus__image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
  }

  .whyus__badge {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    background: var(--green-default);
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--sm);
  }

  .whyus__badge-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
  }

  .whyus__badge-text {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.4;
    margin-top: 3px;
    opacity: 0.85;
  }

  .pillars {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--lg);
  }

  .pillar {
    display: flex;
    gap: var(--md);
    align-items: flex-start;
    padding-bottom: var(--lg);
    border-bottom: 1px solid var(--border);
  }

  .pillar:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pillar__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: var(--green-tint);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pillar__title {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 3px;
  }

  @media (max-width: 900px) {
    .whyus { grid-template-columns: 1fr; }
    .whyus__image { display: none; }
    .whyus__badge { display: none; }
  }
</style>
