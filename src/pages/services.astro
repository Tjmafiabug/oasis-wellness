---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BookCTA from '../components/BookCTA.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';

const categories = site.services;
---

<Layout
  title="Services — OASIS Wave of Wellness"
  description="Explore our full treatment menu: facial rejuvenation, hair restoration, advanced skincare, weight wellness, aesthetic dermatology, and holistic treatments across Delhi NCR."
>
  <Nav />
  <main>

    <!-- Page Hero -->
    <section class="page-hero section--dark">
      <div class="container page-hero__inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">→</span>
          <span>Services</span>
        </nav>
        <span class="label label--gold">Our Expertise</span>
        <h1 class="heading-display">Treatments That<br /><em>Transform</em></h1>
        <p class="page-hero__sub">Six pillars of wellness. Personalised protocols. Results you can see.</p>
      </div>
    </section>

    <!-- Sticky Category Nav -->
    <nav class="category-nav" aria-label="Treatment categories">
      <div class="container category-nav__inner">
        {categories.map(cat => (
          <a href={`#${cat.id}`} class="category-nav__link">{cat.title}</a>
        ))}
      </div>
    </nav>

    <!-- Service Sections -->
    {categories.map((cat, i) => (
      <section
        class={`service-section section ${i % 2 !== 0 ? 'section--tinted' : ''}`}
        id={cat.id}
      >
        <div class="container service-section__inner">
          <div class={`service-section__media${i % 2 !== 0 ? ' service-section__media--right' : ''}`}>
            <div class="service-section__img-wrap">
              <img
                src={cat.img}
                alt={cat.title}
                class="service-section__img"
                loading="lazy"
              />
              <span class="service-section__tag">{cat.tag}</span>
            </div>
          </div>

          <div class="service-section__content">
            <span class="label">{cat.subtitle}</span>
            <h2 class="heading-lg service-section__title">{cat.title}</h2>
            <div class="divider divider--left"></div>
            <p class="body-lg service-section__desc">{cat.desc}</p>

            <ul class="treatment-list">
              {cat.treatments.map(t => (
                <li class="treatment-item">
                  <div class="treatment-item__head">
                    <h3 class="treatment-item__name">{t.name}</h3>
                    <span class="treatment-item__duration">{t.duration}</span>
                  </div>
                  <p class="treatment-item__desc">{t.desc}</p>
                </li>
              ))}
            </ul>

            <a href="/book" class="btn btn--solid" style="margin-top: 2rem; display: inline-flex;">
              Book This Service
            </a>
          </div>
        </div>
      </section>
    ))}

    <BookCTA />
  </main>
  <Footer />
</Layout>

<style>
  /* ── Page Hero ── */
  .page-hero {
    min-height: 340px;
    display: flex;
    align-items: center;
    padding: var(--2xl) 0;
  }

  .page-hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--md);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--xs);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
    margin-bottom: var(--xs);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color var(--duration-sm);
  }

  .breadcrumb a:hover { color: rgba(255,255,255,0.9); }

  .page-hero .heading-display { color: #fff; }

  .page-hero .heading-display em {
    font-style: italic;
    color: var(--gold-light);
  }

  .page-hero__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    max-width: 44ch;
    margin-top: var(--xs);
  }

  /* ── Category Nav ── */
  .category-nav {
    background: #fff;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 109px;
    z-index: 50;
  }

  .category-nav__inner {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .category-nav__inner::-webkit-scrollbar { display: none; }

  .category-nav__link {
    flex-shrink: 0;
    padding: 18px var(--lg);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 2px solid transparent;
    transition: color var(--duration-sm), border-color var(--duration-sm);
  }

  .category-nav__link:hover {
    color: var(--green-default);
    border-bottom-color: var(--green-default);
  }

  /* ── Service Sections ── */
  .service-section__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--2xl);
    align-items: center;
  }

  .service-section__media--right {
    order: 1;
  }

  .service-section__img-wrap {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
  }

  .service-section__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-lg) var(--ease);
  }

  .service-section:hover .service-section__img {
    transform: scale(1.03);
  }

  .service-section__tag {
    position: absolute;
    top: var(--md);
    left: var(--md);
    background: var(--green-default);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
  }

  .service-section__title {
    margin-top: var(--sm);
    margin-bottom: var(--md);
  }

  .service-section__desc {
    margin-top: var(--md);
    margin-bottom: var(--lg);
  }

  /* ── Treatment List ── */
  .treatment-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }

  .treatment-item {
    padding: var(--md) 0;
    border-bottom: 1px solid var(--border);
  }

  .treatment-item__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--md);
    margin-bottom: 4px;
  }

  .treatment-item__name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text);
  }

  .treatment-item__duration {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-default);
  }

  .treatment-item__desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .service-section__inner { grid-template-columns: 1fr; }
    .service-section__media--right { order: 0; }
    .service-section__img-wrap { aspect-ratio: 16/9; }
  }
</style>
