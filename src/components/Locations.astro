---
import { site } from '../config/site';
const locations = site.locations;
---

<section class="section" id="locations">
  <div class="container">
    <header class="section-header">
      <span class="label">Find Us</span>
      <h2 class="heading-lg">Our Locations</h2>
      <div class="divider"></div>
      <p class="body-lg" style="margin-top: 1rem;">
        Three wellness sanctuaries across Delhi NCR, each designed as your personal oasis.
      </p>
    </header>

    <div class="locations__grid">
      {locations.map(l => (
        <article class="location-card">
          <div class="location-card__img-wrap">
            <img src={l.img} alt={`OASIS ${l.city}`} loading="lazy" />
            {l.badge && <span class="location-card__badge">{l.badge}</span>}
            <div class="location-card__overlay">
              <a href="#book" class="btn btn--outline-white">Book Here</a>
            </div>
          </div>
          <div class="location-card__body">
            <div class="location-card__header">
              <div>
                <h3 class="heading-md">{l.city}</h3>
                <span class="label" style="color: var(--gold-default);">{l.area}</span>
              </div>
              <div class="location-card__rating">
                <span class="location-card__stars">
                  {'★'.repeat(Math.floor(parseFloat(l.rating)))}
                </span>
                <span class="location-card__score">{l.rating}</span>
                <span class="location-card__count">({l.reviews} reviews)</span>
              </div>
            </div>
            <p class="body-sm" style="margin-top: 0.5rem;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; vertical-align:-1px; margin-right:4px;">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {l.address}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .locations__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--lg);
  }

  .location-card {
    border: 1px solid var(--border);
    overflow: hidden;
    background: #fff;
  }

  .location-card__img-wrap {
    position: relative;
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .location-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-lg) var(--ease);
  }

  .location-card:hover .location-card__img-wrap img {
    transform: scale(1.04);
  }

  .location-card__badge {
    position: absolute;
    top: var(--md);
    left: var(--md);
    background: var(--gold-default);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
  }

  .location-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--duration-md) var(--ease);
  }

  .location-card:hover .location-card__overlay {
    opacity: 1;
  }

  .location-card__body {
    padding: var(--lg);
  }

  .location-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sm);
  }

  .location-card__rating {
    text-align: right;
    flex-shrink: 0;
  }

  .location-card__stars {
    display: block;
    color: var(--gold-default);
    font-size: 0.65rem;
    letter-spacing: 1px;
  }

  .location-card__score {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--text);
  }

  .location-card__count {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: 3px;
  }

  @media (max-width: 900px) {
    .locations__grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
</style>
